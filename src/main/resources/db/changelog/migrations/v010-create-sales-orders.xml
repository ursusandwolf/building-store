<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="alex">
        <createTable tableName="sales_orders">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_sales_orders_customer" references="users(id)"/>
            </column>
            <column name="status" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="sales_order_lines">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sales_order_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_sales_order_lines_order" references="sales_orders(id)"/>
            </column>
            <column name="product_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_sales_order_lines_product" references="products(id)"/>
            </column>
            <column name="product_name_snapshot" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price_at_order" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="sales_orders" indexName="idx_sales_orders_customer_id">
            <column name="customer_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
