<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="alex">
        <createTable tableName="stock_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_stock_items_product" references="products(id)"/>
            </column>
            <column name="warehouse_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_stock_items_warehouse" references="warehouses(id)"/>
            </column>
            <column name="available_quantity" type="decimal(19,4)" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="reserved_quantity" type="decimal(19,4)" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="damaged_quantity" type="decimal(19,4)" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="stock_items" columnNames="product_id, warehouse_id" constraintName="uk_stock_items_product_warehouse"/>

        <createTable tableName="stock_movements">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_stock_movements_product" references="products(id)"/>
            </column>
            <column name="warehouse_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_stock_movements_warehouse" references="warehouses(id)"/>
            </column>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_after" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="varchar(255)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="stock_items" indexName="idx_stock_items_product_warehouse">
            <column name="product_id"/>
            <column name="warehouse_id"/>
        </createIndex>
        <createIndex tableName="stock_movements" indexName="idx_stock_movements_product_warehouse_created">
            <column name="product_id"/>
            <column name="warehouse_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
