<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="alex">
        <createTable tableName="price_lists">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="start_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="timestamp"/>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="price_list_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="price_list_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_price_list_items_list" references="price_lists(id)"/>
            </column>
            <column name="product_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_price_list_items_product" references="products(id)"/>
            </column>
            <column name="price" type="decimal(19,4)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="price_list_items" indexName="idx_price_list_items_list_product">
            <column name="price_list_id"/>
            <column name="product_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
