<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="alex">
        <createTable tableName="product_packages">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity_in_base_unit" type="decimal(19, 4)">
                <constraints nullable="false"/>
            </column>
            <column name="barcode" type="varchar(50)">
                <constraints unique="true"/>
            </column>
            <column name="is_default_for_sale" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_default_for_purchase" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="product_packages" baseColumnNames="product_id"
                                 constraintName="fk_product_packages_product"
                                 referencedTableName="products" referencedColumnNames="id"/>

        <createIndex tableName="product_packages" indexName="idx_product_packages_product_id">
            <column name="product_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
